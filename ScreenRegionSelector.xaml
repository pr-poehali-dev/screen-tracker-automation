<Window x:Class="MacroFlow.ScreenRegionSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор области"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Normal"
        Cursor="Cross">
    <Grid>
        <!-- Semi-transparent dark overlay (drawn manually in code-behind via Canvas) -->
        <Canvas x:Name="MainCanvas"
                Background="Transparent"
                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                MouseMove="Canvas_MouseMove"
                MouseLeftButtonUp="Canvas_MouseLeftButtonUp">

            <!-- Overlay rectangles will be added dynamically -->

            <!-- Selection rectangle -->
            <Rectangle x:Name="SelectionRect"
                       Stroke="#FF00FF88"
                       StrokeThickness="2"
                       Fill="#3300FF88"
                       Visibility="Collapsed"
                       Canvas.Left="0"
                       Canvas.Top="0" />

            <!-- Coordinate label -->
            <Border x:Name="InfoBorder"
                    Background="#CC1A1A1A"
                    BorderBrush="#FF00FF88"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8,4"
                    Visibility="Collapsed"
                    Canvas.Left="10"
                    Canvas.Top="10">
                <TextBlock x:Name="InfoText"
                           Foreground="#FF00FF88"
                           FontSize="13"
                           FontFamily="Consolas" />
            </Border>

            <!-- Instruction label -->
            <Border x:Name="InstructionBorder"
                    Background="#CC1A1A1A"
                    BorderBrush="#FF3A3A3A"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16,10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Нарисуйте прямоугольник для выбора области экрана. "
                               Foreground="White"
                               FontSize="14" />
                    <TextBlock Text="ESC"
                               Foreground="#FF00FF88"
                               FontSize="14"
                               FontWeight="Bold" />
                    <TextBlock Text=" — отмена"
                               Foreground="White"
                               FontSize="14" />
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
